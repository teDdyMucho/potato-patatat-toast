# Copy this file to ".env" (or ".env.local") and fill in your real values.
# Both are gitignored and will NOT be committed.

# ── OpenAI API (for AI Tools) ──
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Design Adjuster ──
# Optional: override the image-processing webhook (defaults to the Railway URL in code).
# DESIGN_ADJUSTER_WEBHOOK_URL=https://primary-production-6722.up.railway.app/webhook/design-adjuster

# ── Chatbot ──
# Optional: override the chatbot webhook (defaults to the Railway URL in code).
# CHATBOT_WEBHOOK_URL=https://primary-production-6722.up.railway.app/webhook/aktservices-chatbot

# ── Supabase Auth (login / registration / Google sign-in) ──
# Supabase Dashboard → Project Settings → API.
# Both are safe to expose in the browser (that's what NEXT_PUBLIC_ means).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ── Supabase service role (admin dashboard ONLY) ──
# Supabase Dashboard → Project Settings → API → service_role secret.
# SERVER-ONLY. Never prefix with NEXT_PUBLIC_ and never import it into a client
# component — it bypasses Row Level Security. Used by app/api/admin/* routes to
# list all users and write roles. See docs/ADMIN_PAGE.md.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
